# ============================================================
# Banco Alfin — Fuerza de Ventas (Frontend React)
# ============================================================
# Poner VITE_USE_MOCKS=true para desarrollo sin backend.
# Cambiar a false y configurar VITE_API_BASE_URL cuando FastAPI
# esté disponible.
# ============================================================

# Activa datos mock locales (true) o conecta a FastAPI (false)
VITE_USE_MOCKS=true

# URL base del backend FastAPI futuro
VITE_API_BASE_URL=http://localhost:8003
